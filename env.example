import React, { useState, useEffect } from "react";
import * as XLSX from "xlsx";
import { 
  User, Award, Star, FileText, Sparkles, LogOut, 
  Cloud, Download, Upload, Search, Trash2, ShieldAlert,
  Loader2, CheckCircle2, AlertCircle, Info, Printer
} from "lucide-react";

import { Student, ClassConfig } from "./types";
import { INITIAL_STUDENTS, BEHAVIOR_CRITERIA, SKILL_ACTIVITIES } from "./data";

// Sub-components
import LoginScreen from "./components/LoginScreen";
import ClassConfigCard from "./components/ClassConfigCard";
import NewStudentForm from "./components/NewStudentForm";
import ReportCard from "./components/ReportCard";
import BehaviorTab from "./components/BehaviorTab";
import SkillsTab from "./components/SkillsTab";
import AiHelperTab from "./components/AiHelperTab";

export default function App() {
  const [isAuthenticated, setIsAuthenticated] = useState(false);

  // Classroom profiles
  const [classConfig, setClassConfig] = useState<ClassConfig>({
    schoolName: "សាលាបឋមសិក្សា ម៉ឹង សំផន",
    className: "ថ្នាក់ទី ៦ ក",
    academicYear: "២០២៥-២០២៦"
  });

  // Students profiles
  const [students, setStudents] = useState<Student[]>([]);
  const [activeStudentId, setActiveStudentId] = useState<string | null>(null);
  const [selectedClassFilter, setSelectedClassFilter] = useState<string>("ថ្នាក់ទី ៦ ក");
  const [searchQuery, setSearchQuery] = useState("");
  const [activeTab, setActiveTab] = useState<string>("list");

  // Integrations and backups
  const [geminiApiKey, setGeminiApiKey] = useState("");
  const [googleSheetUrl, setGoogleSheetUrl] = useState("");

  // UI systems
  const [syncing, setSyncing] = useState(false);
  const [isBulkPrinting, setIsBulkPrinting] = useState(false);
  const [toast, setToast] = useState<{ message: string; type: "success" | "error" } | null>(null);
  const [confirmModal, setConfirmModal] = useState<{ 
    isOpen: boolean; 
    title: string; 
    message: string; 
    onConfirm: () => void 
  } | null>(null);

  // Initialize data on load
  useEffect(() => {
    const authed = sessionStorage.getItem("moeys_authenticated") === "true";
    setIsAuthenticated(authed);

    const savedStudents = localStorage.getItem("moeys_students_eval_v5");
    const savedConfig = localStorage.getItem("moeys_class_config_v5");
    const savedApiKey = localStorage.getItem("moeys_gemini_api_key_v5");
    const savedSheetUrl = localStorage.getItem("moeys_google_sheet_url_v5");

    if (savedStudents) {
      try {
        const parsed = JSON.parse(savedStudents);
        setStudents(parsed);
      } catch (err) {
        setStudents(INITIAL_STUDENTS);
      }
    } else {
      setStudents(INITIAL_STUDENTS);
    }

    if (savedConfig) {
      try {
        setClassConfig(JSON.parse(savedConfig));
      } catch (err) {}
    }

    if (savedApiKey) setGeminiApiKey(savedApiKey);
    if (savedSheetUrl) setGoogleSheetUrl(savedSheetUrl);
  }, []);

  // Update active student based on selections or school class filtering
  const getFilteredStudents = () => {
    if (selectedClassFilter === "បង្ហាញទាំងអស់") {
      return students;
    }
    return students.filter(s => (s.className || classConfig.className) === selectedClassFilter);
  };

  const activeFiltered = getFilteredStudents();

  useEffect(() => {
    if (activeFiltered.length > 0 && (!activeStudentId || !students.some(s => s.id === activeStudentId))) {
      setActiveStudentId(activeFiltered[0].id);
    } else if (students.length > 0 && !activeStudentId) {
      setActiveStudentId(students[0].id);
    }
  }, [students, selectedClassFilter]);

  // Persists states automatically
  const saveStudents = (updatedStudents: Student[]) => {
    setStudents(updatedStudents);
    localStorage.setItem("moeys_students_eval_v5", JSON.stringify(updatedStudents));
  };

  const handleConfigChange = (newConfig: ClassConfig) => {
    setClassConfig(newConfig);
    localStorage.setItem("moeys_class_config_v5", JSON.stringify(newConfig));
  };

  const handleGoogleSheetUrlChange = (url: string) => {
    setGoogleSheetUrl(url);
    localStorage.setItem("moeys_google_sheet_url_v5", url);
  };

  const handleApiKeyChange = (key: string) => {
    setGeminiApiKey(key);
    localStorage.setItem("moeys_gemini_api_key_v5", key);
  };

  // Helper trigger overlays
  const showToast = (message: string, type: "success" | "error" = "success") => {
    setToast({ message, type });
    setTimeout(() => setToast(null), 4000);
  };

  const triggerConfirm = (title: string, message: string, onConfirm: () => void) => {
    setConfirmModal({
      isOpen: true,
      title,
      message,
      onConfirm: () => {
        onConfirm();
        setConfirmModal(null);
      }
    });
  };

  // Student management events
  const handleAddStudent = (profile: { studentId: string; nameKh: string; gender: "ប្រុស" | "ស្រី" }) => {
    const isConflict = students.some(s => s.studentId === profile.studentId && (s.className || classConfig.className) === classConfig.className);
    if (isConflict) {
      showToast("អត្តលេខសិស្សនេះមានបញ្ចូលរួចរាល់នៅក្នុងថ្នាក់នេះហើយ!", "error");
      return;
    }

    const created: Student = {
      id: "st_" + Date.now(),
      studentId: profile.studentId,
      nameKh: profile.nameKh,
      nameEn: "",
      gender: profile.gender,
      className: classConfig.className,
      aiComment: "",
      behavior: { cleanliness: [], politeness: [], orderliness: [], punctuality: [], mindfulness: [] },
      skills: {}
    };

    const next = [...students, created];
    saveStudents(next);
    setActiveStudentId(created.id);
    showToast("បានបន្ថែមសិស្សថ្មីដោយជោគជ័យ!");
  };

  const handleDeleteStudent = (id: string) => {
    triggerConfirm(
      "លុបទិន្នន័យសិស្ស",
      "តើលោកគ្រូអ្នកគ្រូពិតជាចង់លុបទិន្នន័យរបស់សិស្សនេះមែនទេ? រាល់ពិន្ទុដែលបានបំពេញនឹងត្រូវបាត់បង់ជារៀងរហូត។",
      () => {
        const next = students.filter(s => s.id !== id);
        saveStudents(next);
        if (activeStudentId === id) {
          setActiveStudentId(next.length > 0 ? next[0].id : null);
        }
        showToast("បានលុបទិន្នន័យសិស្សរួចរាល់!", "error");
      }
    );
  };

  const handleToggleGender = (id: string) => {
    const next = students.map((s) => {
      if (s.id === id) {
        return {
          ...s,
          gender: (s.gender === "ប្រុស" ? "ស្រី" : "ប្រុស") as "ប្រុស" | "ស្រី"
        };
      }
      return s;
    });
    saveStudents(next);
    showToast("បានធ្វើបច្ចុប្បន្នភាពភេទសិស្សរួចរាល់!");
  };

  const handleToggleBehaviorItem = (studentId: string, category: string, itemId: string) => {
    const next = students.map((s) => {
      if (s.id === studentId) {
        const currentList = s.behavior[category] || [];
        const isChecked = currentList.includes(itemId);
        return {
          ...s,
          behavior: {
            ...s.behavior,
            [category]: isChecked 
              ? currentList.filter(id => id !== itemId) 
              : [...currentList, itemId]
          }
        };
      }
      return s;
    });
    saveStudents(next);
  };

  const handleUpdateSkillScore = (studentId: string, activityId: string, value: number) => {
    const next = students.map((s) => {
      if (s.id === studentId) {
        return {
          ...s,
          skills: {
            ...s.skills,
            [activityId]: value
          }
        };
      }
      return s;
    });
    saveStudents(next);
  };

  const handleCommentChange = (studentId: string, comment: string) => {
    const next = students.map((s) => {
      if (s.id === studentId) {
        return { ...s, aiComment: comment };
      }
      return s;
    });
    saveStudents(next);
  };

  // Evaluation levels mapping
  const getBehaviorLevel = (score: number) => {
    if (score >= 54) return { text: "ល្អណាស់", color: "text-emerald-600 bg-emerald-50 border-emerald-200" };
    if (score >= 45) return { text: "ល្អ", color: "text-blue-600 bg-blue-50 border-blue-200" };
    if (score >= 30) return { text: "មធ្យម", color: "text-amber-600 bg-amber-50 border-amber-200" };
    return { text: "ត្រូវកែលម្អ", color: "text-rose-600 bg-rose-50 border-rose-200" };
  };

  const getSkillLevel = (score: number) => {
    if (score >= 64) return { text: "ល្អណាស់", color: "text-emerald-600 bg-emerald-50 border-emerald-200" };
    if (score >= 50) return { text: "ល្អ", color: "text-blue-600 bg-blue-50 border-blue-200" };
    if (score >= 36) return { text: "មធ្យម", color: "text-amber-600 bg-amber-50 border-amber-200" };
    return { text: "ត្រូវកែលម្អ", color: "text-rose-600 bg-rose-50 border-rose-200" };
  };

  // Google sheet syncer
  const syncToGoogleSheets = async () => {
    if (!googleSheetUrl.trim()) {
      showToast("សូមកំណត់បញ្ចូលតំណភ្ជាប់ Google Sheet Web App URL ជាមុនសិន!", "error");
      setActiveTab("list");
      return;
    }

    setSyncing(true);
    let studentsToSync = getFilteredStudents();

    // Ensure all items are formatted for deployment
    const payload = {
      students: studentsToSync.map(s => ({
        ...s,
        className: s.className || classConfig.className
      })),
      classConfig: {
        ...classConfig,
        className: selectedClassFilter === "បង្ហាញទាំងអស់" ? classConfig.className : selectedClassFilter
      }
    };

    try {
      await fetch(googleSheetUrl, {
        method: "POST",
        mode: "no-cors",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      showToast("សមកាលកម្មទៅកាន់ Google Sheets រួចរាល់ដោយជោគជ័យ!");
    } catch (err: any) {
      showToast("ការបញ្ជូនទិន្នន័យទៅ Google Sheets បរាជ័យ៖ " + err.message, "error");
    } finally {
      setSyncing(false);
    }
  };

  // SheetJS Excel exporting engine
  const exportToExcel = () => {
    try {
      const wb = XLSX.utils.book_new();

      // Tab 1: Summaries
      const summaryData = students.map((s) => {
        let bScore = 0;
        Object.keys(s.behavior).forEach((key) => {
          bScore += s.behavior[key]?.length || 0;
        });

        let sScore = 0;
        Object.values(s.skills || {}).forEach((val) => {
          sScore += (val as number) || 0;
        });

        return {
          "អត្តលេខសិស្ស": s.studentId,
          "ឈ្មោះខ្មែរ": s.nameKh,
          "ឈ្មោះឡាតាំង": s.nameEn || "",
          "ភេទ": s.gender,
          "ថ្នាក់": s.className || classConfig.className,
          "ចរិយាសម្បទា_ស្អាត": s.behavior.cleanliness?.length || 0,
          "ចរិយាសម្បទា_សុភាព": s.behavior.politeness?.length || 0,
          "ចរិយាសម្បទា_របៀប": s.behavior.orderliness?.length || 0,
          "ចរិយាសម្បទា_ទៀងពេល": s.behavior.punctuality?.length || 0,
          "ចរិយាសម្បទា_សម្មាធិ": s.behavior.mindfulness?.length || 0,
          "ពិន្ទុចរិយាសម្បទាសរុប": bScore,
          "ពិន្ទុបំណិនសម្បទាសរុប": sScore,
          "មតិវាយតម្លៃ_AI": s.aiComment || ""
        };
      });
      const ws1 = XLSX.utils.json_to_sheet(summaryData);
      XLSX.utils.book_append_sheet(wb, ws1, "ព័ត៌មាន និងពិន្ទុរួម");

      // Tab 2: Detailed checks
      const behaviorData = students.map((s) => {
        const row: any = { "អត្តលេខសិស្ស": s.studentId, "ឈ្មោះខ្មែរ": s.nameKh };
        Object.keys(BEHAVIOR_CRITERIA).forEach((cat) => {
          BEHAVIOR_CRITERIA[cat].items.forEach((item) => {
            const colName = `${BEHAVIOR_CRITERIA[cat].title.split(" ")[0]}_${item.id}_${item.text}`;
            row[colName] = s.behavior[cat]?.includes(item.id) ? "✓" : "";
          });
        });
        return row;
      });
      const ws2 = XLSX.utils.json_to_sheet(behaviorData);
      XLSX.utils.book_append_sheet(wb, ws2, "ទិន្នន័យចរិយាសម្បទាលម្អិត");

      // Tab 3: Extracurricular skills
      const skillData = students.map((s) => {
        const row: any = { "អត្តលេខសិស្ស": s.studentId, "ឈ្មោះខ្មែរ": s.nameKh };
        SKILL_ACTIVITIES.forEach((act, idx) => {
          const colName = `សកម្មភាព_${idx + 1}_${act.text}`;
          row[colName] = s.skills?.[act.id] ?? 0;
        });
        return row;
      });
      const ws3 = XLSX.utils.json_to_sheet(skillData);
      XLSX.utils.book_append_sheet(wb, ws3, "ទិន្នន័យបំណិនសម្បទាលម្អិត");

      XLSX.writeFile(wb, "MoEYS_Student_Scores_2026.xlsx");
      showToast("ទាញទិន្នន័យចេញជា Excel ជោគជ័យ!");
    } catch (err: any) {
      showToast("ការទាញចេញជា Excel បរាជ័យ!", "error");
    }
  };

  // SheetJS Excel importer
  const importFromExcel = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (evt) => {
      try {
        const bstr = evt.target?.result as string;
        const wb = XLSX.read(bstr, { type: "binary" });

        const ws1 = wb.Sheets[wb.SheetNames[0]];
        const summaryRows = XLSX.utils.sheet_to_json<any>(ws1);

        if (summaryRows.length === 0) {
          showToast("ឯកសារ Excel គ្មានទិន្នន័យសិស្សឡើយ!", "error");
          return;
        }

        const imported: Student[] = summaryRows
          .map((row, idx): Student | null => {
            // Retrieve Student ID column
            const studentIdRaw = row["អត្តលេខ"] || row["អត្តលេខសិស្ស"] || row["ID"] || row["អត្តលេខសិស្ស"];
            if (!studentIdRaw) return null; // Skip empty rows

            const studentId = String(studentIdRaw).trim();
            
            // Retrieve Name column
            const nameKhRaw = row["ឈ្មោះសិស្ស"] || row["ឈ្មោះខ្មែរ"] || row["ឈ្មោះជាភាសាខ្មែរ"] || row["ឈ្មោះ"] || row["Name"];
            const nameKh = nameKhRaw ? String(nameKhRaw).trim() : "សិស្សគ្មានឈ្មោះ";

            // Retrieve Gender column
            const genderRaw = row["ភេទ"] || row["Gender"] || "ប្រុស";
            const genderStr = String(genderRaw).trim();
            const gender = (genderStr === "ស្រី" || genderStr.toLowerCase() === "female" || genderStr.toLowerCase() === "f") ? ("ស្រី" as const) : ("ប្រុស" as const);

            // Retrieve Class/Grade column
            const classRaw = row["ថ្នាក់ទី"] || row["ថ្នាក់"] || row["Class"] || classConfig.className;
            const studentClass = classRaw ? String(classRaw).trim() : classConfig.className;

            // Initialize behavior and skills
            const behaviorObj: Student["behavior"] = { 
              cleanliness: [], 
              politeness: [], 
              orderliness: [], 
              punctuality: [], 
              mindfulness: [] 
            };

            const skillsObj: any = {};
            SKILL_ACTIVITIES.forEach((act) => {
              skillsObj[act.id] = 0;
            });

            return {
              id: `st_${Date.now()}_${idx}_${Math.random().toString(36).substr(2, 5)}`,
              studentId,
              nameKh,
              nameEn: "",
              gender,
              className: studentClass,
              aiComment: "",
              behavior: behaviorObj,
              skills: skillsObj
            };
          })
          .filter((s): s is Student => s !== null);

        if (imported.length === 0) {
          showToast("មិនអាចស្វែងរកទិន្នន័យសិស្សត្រឹមត្រូវដែលមាន អត្តលេខ និង ឈ្មោះសិស្ស ទេ!", "error");
          return;
        }

        // Set state to imported students
        saveStudents(imported);
        if (imported.length > 0) {
          setSelectedClassFilter(imported[0].className || classConfig.className);
          setActiveStudentId(imported[0].id);
        }
        showToast(`បានបញ្ចូលសិស្សចំនួន ${imported.length} នាក់ ពី Excel ដោយជោគជ័យ!`);
      } catch (err: any) {
        showToast("ការអានឯកសារ Excel បរាជ័យ! សូមពិនិត្យគំរូឡើងវិញ។", "error");
      }
    };
    reader.readAsBinaryString(file);
    e.target.value = "";
  };

  // Download template mockup xlsx conforming to columns requested: 
  // 1. អត្តលេខ, 2. ឈ្មោះសិស្ស, 3. ភេទ, 4. ថ្នាក់ទី
  const downloadImportTemplate = () => {
    try {
      const wb = XLSX.utils.book_new();

      const sampleList = [
        { "អត្តលេខ": "ST-2026-001", "ឈ្មោះសិស្ស": "សុខ ជា", "ភេទ": "ប្រុស", "ថ្នាក់ទី": classConfig.className || "ថ្នាក់ទី ៦ ក" },
        { "អត្តលេខ": "ST-2026-002", "ឈ្មោះសិស្ស": "ចាន់ ស្រីនី", "ភេទ": "ស្រី", "ថ្នាក់ទី": classConfig.className || "ថ្នាក់ទី ៦ ក" },
        { "អត្តលេខ": "ST-2026-003", "ឈ្មោះសិស្ស": "គឹម ហេង", "ភេទ": "ប្រុស", "ថ្នាក់ទី": classConfig.className || "ថ្នាក់ទី ៦ ក" },
        { "អត្តលេខ": "ST-2026-004", "ឈ្មោះសិស្ស": "លី សុភ័ក្រ", "ភេទ": "ស្រី", "ថ្នាក់ទី": classConfig.className || "ថ្នាក់ទី ៦ ក" },
        { "អត្តលេខ": "ST-2026-005", "ឈ្មោះសិស្ស": "ម៉ៅ សុខា", "ភេទ": "ប្រុស", "ថ្នាក់ទី": classConfig.className || "ថ្នាក់ទី ៦ ក" }
      ];

      const ws = XLSX.utils.json_to_sheet(sampleList);
      XLSX.utils.book_append_sheet(wb, ws, "បញ្ជីឈ្មោះសិស្ស");

      XLSX.writeFile(wb, "MoEYS_Student_Import_Template.xlsx");
      showToast("ទាញយកគំរូ Excel សម្រាប់នាំចូលជោគជ័យ!");
    } catch (err) {
      showToast("ការទាញយកគំរូ Excel បរាជ័យ!", "error");
    }
  };

  // backup JSON
  const exportJSONBackup = () => {
    const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify({ students, classConfig }, null, 2));
    const downloadAnchor = document.createElement("a");
    downloadAnchor.setAttribute("href", dataStr);
    downloadAnchor.setAttribute("download", `MoEYS_Backup_${new Date().toLocaleDateString()}.json`);
    document.body.appendChild(downloadAnchor);
    downloadAnchor.click();
    downloadAnchor.remove();
    showToast("បានរក្សាទុក JSON Backup ជោគជ័យ!");
  };

  // Calls our backend secure API for Gemini analysis
  const handleTriggerGenerateReport = async (studentId: string, customApiKey?: string) => {
    const targetStudent = students.find(s => s.id === studentId);
    if (!targetStudent) return null;

    let bScore = 0;
    Object.keys(targetStudent.behavior).forEach((key) => {
      bScore += targetStudent.behavior[key]?.length || 0;
    });

    let sScore = 0;
    Object.values(targetStudent.skills || {}).forEach((val) => {
      sScore += (val as number) || 0;
    });

    const bLvlText = getBehaviorLevel(bScore).text;
    const sLvlText = getSkillLevel(sScore).text;

    // Collect checkbox missing values to provide in the prompt context
    let lackingList: string[] = [];
    Object.keys(BEHAVIOR_CRITERIA).forEach((key) => {
      const items = BEHAVIOR_CRITERIA[key].items;
      const checked = targetStudent.behavior[key] || [];
      items.forEach((it) => {
        if (!checked.includes(it.id)) lackingList.push(it.text);
      });
    });
    const lackingStr = lackingList.slice(0, 4).join(", ") || "គ្មានចំណុចខ្វះចន្លោះធំដុំទេ";

    const promptText = `សូមបង្កើតសេចក្តីសន្និដ្ឋានរួមវាយតម្លៃ និងការណែនាំអប់រំសម្រាប់សិស្សម្នាក់៖
- ឈ្មោះសិស្ស៖ ${targetStudent.nameKh} (ភេទ៖ ${targetStudent.gender})
- ពិន្ទុចរិយាសម្បទា (៥ សកម្មភាព)៖ ${bScore}/60 (កម្រិតវាយតម្លៃ៖ ${bLvlText})
- ចំណុចខ្វះចន្លោះផ្នែកចរិយាសម្បទាដែលគួរជួយបន្ថែម៖ ${lackingStr}
- ពិន្ទុបំណិនសម្បទា (១៨ សកម្មភាព)៖ ${sScore}/72 (កម្រិតវាយតម្លៃ៖ ${sLvlText})`;

    const systemPrompt = `អ្នកគឺជាប្រព័ន្ធបញ្ញាសិប្បនិម្មិត (AI) ផ្លូវការរបស់ក្រសួងអប់រំ យុវជន និងកីឡា នៃព្រះរាជាណាកម្ពុជា។
ភារកិច្ចរបស់អ្នកគឺជួយលោកគ្រូអ្នកគ្រូក្នុងការសរសេរ «មតិវាយតម្លៃរួមរបស់គ្រូ និងដំបូន្មានសម្រាប់អាណាព្យាបាល»។
សូមសរសេរជាភាសាខ្មែរផ្លូវការ ខ្លីខ្លឹម ត្រឹមត្រូវតាមអក្ខរាវិរុទ្ធ (ដោយប្រើប្រាស់ពាក្យពេចន៍សមរម្យសម្រាប់សាលារៀនខ្មែរ) និងមានលក្ខណៈអប់រំលើកទឹកចិត្តជានិច្ច។
ទម្រង់នៃការឆ្លើយតបត្រូវតែមាន៖
១. ការវាយតម្លៃរួម (ចំណុចខ្លាំង ចំណុចត្រូវកែលម្អ)
២. អនុសាសន៍អប់រំខ្លីៗសម្រាប់អាណាព្យាបាលសិស្សយកទៅជួយជម្រុញនៅផ្ទះ (៣ ទៅ ៤ ចំណុចច្បាស់ៗ)

ចំណាំ៖ មិនត្រូវសរសេរពាក្យអង់គ្លេស ឬសញ្ញាពិសេសច្រើនពេកទេ ត្រូវសម្រួលឱ្យស្របគ្នានឹងការបោះពុម្ពសន្លឹកបញ្ជាក់គុណវុឌ្ឍិផ្លូវការ។`;

    const response = await fetch("/api/gemini/generate", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        prompt: promptText,
        systemInstruction: systemPrompt,
        userApiKey: customApiKey || geminiApiKey
      })
    });

    const data = await response.json();
    if (!response.ok) {
      throw new Error(data.error || "Failed to utilize server-side AI processing.");
    }

    // Save final AI comments
    const next = students.map((s) => {
      if (s.id === studentId) return { ...s, aiComment: data.text };
      return s;
    });
    saveStudents(next);
    showToast("Gemini បានបង្កើតមតិវាយតម្លៃស្អាតៗ និងរក្សាទុកចូលសន្លឹកពិន្ទុរួចរាល់!");
    return data.text as string;
  };

  const handlePrintAll = () => {
    setIsBulkPrinting(true);
    setTimeout(() => {
      window.print();
      setIsBulkPrinting(false);
    }, 500);
  };

  // Class filtering utilities
  const handleActiveStudentChange = (id: string) => {
    setActiveStudentId(id);
  };

  const handleFilterChange = (val: string) => {
    setSelectedClassFilter(val);
    if (val !== "បង្ហាញទាំងអស់") {
      setClassConfig({ ...classConfig, className: val });
    }
  };

  // Statistics summaries logic
  const getTotalsSummary = () => {
    const list = getFilteredStudents();
    const count = list.length;
    const girls = list.filter(s => s.gender === "ស្រី").length;

    let bSum = 0;
    let sSum = 0;
    list.forEach((s) => {
      Object.keys(s.behavior).forEach(k => bSum += s.behavior[k]?.length || 0);
      Object.values(s.skills || {}).forEach(v => sSum += (v as number) || 0);
    });

    const avgB = count > 0 ? (bSum / count).toFixed(1) : "0";
    const avgS = count > 0 ? (sSum / count).toFixed(1) : "0";

    return { total: count, females: girls, avgBehavior: avgB, avgSkill: avgS };
  };

  const stats = getTotalsSummary();

  const handleLogout = () => {
    triggerConfirm(
      "ចាកចេញពីប្រព័ន្ធ",
      "តើលោកគ្រូអ្នកគ្រូពិតជាចង់ចាកចេញពីគណនីបច្ចុប្បន្នមែនទេ?",
      () => {
        sessionStorage.removeItem("moeys_authenticated");
        setIsAuthenticated(false);
        showToast("លោកគ្រូ/អ្នកគ្រូបានចាកចេញពីប្រព័ន្ធដោយជោគជ័យ។");
      }
    );
  };

  // Load the active student reference
  const activeStudent = students.find((s) => s.id === activeStudentId) || null;

  // Retrieve unique classrooms as options for filter
  const classesList = students.map(s => s.className || classConfig.className);
  const uniqueClassrooms = ["បង្ហាញទាំងអស់", ...Array.from(new Set(classesList))].filter(Boolean);

  if (!isAuthenticated) {
    return <LoginScreen onLoginSuccess={() => setIsAuthenticated(true)} />;
  }

  return (
    <div className="bg-slate-100 text-slate-800 font-sans text-xs min-h-screen flex flex-col relative">
      
      {/* Toast Alert Popup notifications */}
      {toast && (
        <div 
          className={`fixed bottom-5 right-5 z-50 px-5 py-3.5 rounded-xl shadow-2xl border flex items-center gap-3 transition-all duration-300 pointer-events-none font-bold ${
            toast.type === "success" ? "bg-emerald-600 border-emerald-500 text-white" : "bg-rose-600 border-rose-500 text-white"
          }`}
        >
          {toast.type === "success" ? <CheckCircle2 className="w-5 h-5 text-emerald-100" /> : <AlertCircle className="w-5 h-5 text-rose-100" />}
          <span className="text-xs font-bold leading-relaxed">{toast.message}</span>
        </div>
      )}

      {/* Confirmation modal wrapper */}
      {confirmModal?.isOpen && (
        <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm no-print-element text-xs">
          <div className="bg-white rounded-xl shadow-xl max-w-md w-full border border-slate-100 overflow-hidden">
            <div className="p-5 space-y-3">
              <div className="flex items-center gap-3 text-rose-600">
                <ShieldAlert className="w-6 h-6 flex-shrink-0" />
                <h4 className="font-bold text-sm md:text-base font-muol leading-relaxed">{confirmModal.title}</h4>
              </div>
              <p className="text-xs text-slate-600 leading-relaxed font-semibold">{confirmModal.message}</p>
            </div>
            <div className="bg-slate-50 px-5 py-3.5 flex justify-end gap-2.5 border-t border-slate-100">
              <button 
                onClick={() => setConfirmModal(null)} 
                className="px-4 py-1.5 bg-white border border-slate-200 hover:bg-slate-100 text-slate-700 font-bold rounded-lg cursor-pointer"
              >
                បោះបង់
              </button>
              <button 
                onClick={confirmModal.onConfirm} 
                className="px-4 py-1.5 bg-rose-600 hover:bg-rose-500 text-white font-bold rounded-lg cursor-pointer"
              >
                យល់ព្រម
              </button>
            </div>
          </div>
        </div>
      )}

      {/* Bulk printing sandbox loop (Rendered only on print triggers) */}
      {isBulkPrinting && (
        <div id="bulk-print-section" className="absolute inset-0 bg-white z-[9999] p-0 m-0">
          {activeFiltered.map((s, idx) => (
            <div key={s.id} className={`bulk-print-page print-card bg-white p-8 ${idx < activeFiltered.length - 1 ? 'page-break-after' : ''}`}>
              <ReportCard 
                student={s}
                classConfig={classConfig}
                onTriggerAiComment={async () => ""}
                getBehaviorLevel={getBehaviorLevel}
                getSkillLevel={getSkillLevel}
              />
            </div>
          ))}
        </div>
      )}

      {/* Premium Desktop Headings */}
      <header className="bg-gradient-to-r from-teal-950 via-teal-900 to-emerald-950 text-white shadow-xl border-b border-teal-800/40 no-print-element">
        <div className="max-w-7xl mx-auto px-4 py-5 sm:px-6 lg:px-8">
          <div className="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-5">
            <div className="flex items-center space-x-4">
              <div className="p-1 bg-white rounded-2xl shadow-lg shadow-teal-950/45 transform hover:scale-105 transition-transform flex items-center justify-center w-16 h-16 shrink-0 border border-white/20">
                <img 
                  src="https://lh3.googleusercontent.com/d/1L6k3hiIN-0sWPSNGDN3YJTsTYgzYS8Dn" 
                  alt="សាលាបឋមសិក្សា ម៉ឹង សំផន" 
                  className="w-14 h-14 object-contain rounded-xl" 
                  onError={(e) => {
                    (e.target as HTMLImageElement).src = 'https://placehold.co/150x150/0f766e/ffffff?text=%E1%9E%98%E1%9F%8Grid';
                  }}
                />
              </div>
              <div>
                <h1 className="text-lg md:text-xl font-muol leading-relaxed tracking-wide text-amber-400">
                  កម្មវិធីវាយតម្លៃពិន្ទុ ចរិយាសម្បទា និងបំណិនសម្បទា
                </h1>
                <p className="text-xs text-teal-100/85 mt-1 flex items-center gap-2">
                  <span className="inline-block w-2.5 h-2.5 bg-emerald-400 rounded-full animate-ping"></span>
                  សាលាបឋមសិក្សា ម៉ឹង សំផន • ប្រព័ន្ធគ្រប់គ្រងឌីជីថលគាំទ្រ Excel និង Gemini AI
                </p>
              </div>
            </div>

            <div className="flex flex-wrap items-center gap-2 text-xs">
              <button 
                id="header-btn-sync" 
                disabled={syncing}
                onClick={syncToGoogleSheets} 
                className="inline-flex items-center px-3.5 py-2 bg-blue-600 hover:bg-blue-500 hover:-translate-y-0.5 text-white font-bold rounded-xl shadow-md transition-all duration-300 cursor-pointer disabled:bg-blue-450"
              >
                {syncing ? <Loader2 className="w-4 h-4 mr-1.5 animate-spin" /> : <Cloud className="w-4 h-4 mr-1.5" />}
                បញ្ជូនទៅ Google Sheets
              </button>

              <button 
                onClick={downloadImportTemplate} 
                className="inline-flex items-center px-3.5 py-2 bg-amber-600 hover:bg-amber-500 hover:-translate-y-0.5 text-white font-bold rounded-xl shadow-md transition-all duration-300 cursor-pointer"
              >
                <Download className="w-4 h-4 mr-1.5" />ទាញយកគំរូ Excel
              </button>

              <button 
                onClick={exportToExcel} 
                className="inline-flex items-center px-3.5 py-2 bg-emerald-600 hover:bg-emerald-500 hover:-translate-y-0.5 text-white font-bold rounded-xl shadow-md transition-all duration-300 cursor-pointer"
              >
                <Download className="w-4 h-4 mr-1.5" />ទាញចេញ Excel (.xlsx)
              </button>

              <label className="inline-flex items-center px-3.5 py-2 bg-teal-600 hover:bg-teal-500 hover:-translate-y-0.5 text-white font-bold rounded-xl shadow-md transition-all duration-300 cursor-pointer">
                <Upload className="w-4 h-4 mr-1.5" />បញ្ចូលពី Excel (.xlsx)
                <input 
                  type="file" 
                  accept=".xlsx, .xls" 
                  className="hidden" 
                  onChange={importFromExcel} 
                />
              </label>

              <button 
                onClick={exportJSONBackup} 
                className="p-2 bg-slate-800 hover:bg-slate-700 hover:-translate-y-0.5 text-slate-300 hover:text-white rounded-xl transition-all shadow" 
                title="រក្សាទុក JSON Backup"
              >
                <Download className="w-4 h-4" />
              </button>

              <button 
                onClick={handleLogout} 
                className="p-2 bg-rose-600 hover:bg-rose-500 hover:-translate-y-0.5 text-white rounded-xl transition-all shadow-md shadow-rose-650/20" 
                title="ចាកចេញពីប្រព័ន្ធ (Logout)"
              >
                <LogOut className="w-4 h-4" />
              </button>
            </div>
          </div>
        </div>
      </header>

      {/* Tabs Menu Navigation Bar */}
      <nav className="bg-white/90 backdrop-blur-md border-b border-slate-200/80 sticky top-0 z-30 shadow-sm no-print-element">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="flex items-center justify-between py-2.5">
            <div className="flex items-center gap-2 overflow-x-auto no-scrollbar w-full py-1">
              
              <button 
                onClick={() => setActiveTab("list")} 
                className={`flex items-center gap-2 px-5 py-2.5 rounded-xl text-xs md:text-sm font-bold whitespace-nowrap transition-all duration-300 cursor-pointer ${
                  activeTab === "list" 
                    ? "bg-gradient-to-r from-teal-600 to-emerald-600 text-white shadow-md border border-teal-500/20 scale-[1.02]" 
                    : "bg-slate-100 text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 font-medium"
                }`}
              >
                <User className="w-4.5 h-4.5" />
                <span>បញ្ជីឈ្មោះសិស្ស</span>
              </button>

              <button 
                onClick={() => setActiveTab("behavior")} 
                className={`flex items-center gap-2 px-5 py-2.5 rounded-xl text-xs md:text-sm font-bold whitespace-nowrap transition-all duration-300 cursor-pointer ${
                  activeTab === "behavior" 
                    ? "bg-gradient-to-r from-teal-600 to-emerald-600 text-white shadow-md border border-teal-500/20 scale-[1.02]" 
                    : "bg-slate-100 text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 font-medium"
                }`}
              >
                <Award className="w-4.5 h-4.5" />
                <span>វាយតម្លៃចរិយាសម្បទា</span>
              </button>

              <button 
                onClick={() => setActiveTab("skills")} 
                className={`flex items-center gap-2 px-5 py-2.5 rounded-xl text-xs md:text-sm font-bold whitespace-nowrap transition-all duration-300 cursor-pointer ${
                  activeTab === "skills" 
                    ? "bg-gradient-to-r from-teal-600 to-emerald-600 text-white shadow-md border border-teal-500/20 scale-[1.02]" 
                    : "bg-slate-100 text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 font-medium"
                }`}
              >
                <Star className="w-4.5 h-4.5" />
                <span>វាយតម្លៃបំណិនសម្បទា</span>
              </button>

              <button 
                onClick={() => setActiveTab("report")} 
                className={`flex items-center gap-2 px-5 py-2.5 rounded-xl text-xs md:text-sm font-bold whitespace-nowrap transition-all duration-300 cursor-pointer ${
                  activeTab === "report" 
                    ? "bg-gradient-to-r from-teal-600 to-emerald-600 text-white shadow-md border border-teal-500/20 scale-[1.02]" 
                    : "bg-slate-100 text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 font-medium"
                }`}
              >
                <FileText className="w-4.5 h-4.5" />
                <span>សន្លឹកវាយតម្លៃការសិក្សា</span>
              </button>

              <button 
                onClick={() => setActiveTab("ai-helper")} 
                className={`flex items-center gap-2 px-5 py-2.5 rounded-xl text-xs md:text-sm font-bold whitespace-nowrap transition-all duration-300 cursor-pointer ${
                  activeTab === "ai-helper" 
                    ? "bg-gradient-to-r from-teal-600 to-emerald-600 text-white shadow-md border border-teal-500/20 scale-[1.02]" 
                    : "bg-slate-100 text-slate-600 hover:text-slate-900 hover:bg-slate-200/60 font-medium"
                }`}
              >
                <Sparkles className="w-4.5 h-4.5" />
                <span>ជំនួយការ AI (Gemini Direct)</span>
              </button>

            </div>
          </div>
        </div>
      </nav>

      {/* Main Workspace Frame container */}
      <main className="flex-grow max-w-7xl mx-auto w-full px-4 py-6 sm:px-6 lg:px-8 print:p-0">

        {/* Tab 1: Student List Tab */}
        {activeTab === "list" && (
          <div className="space-y-6 animate-fade-in no-print-element">
            
            {/* Guide notes */}
            <div className="bg-gradient-to-r from-emerald-50 to-teal-50 border border-emerald-200/60 p-4 rounded-xl shadow-sm flex items-start gap-3">
              <div className="p-2 bg-emerald-100 rounded-lg text-emerald-700 mt-0.5">
                <FileText className="w-5 h-5" />
              </div>
              <div className="text-xs text-slate-700 space-y-2 flex-grow">
                <h4 className="font-bold text-emerald-900 font-muol leading-relaxed">💡 គន្លឹះនាំចូលបញ្ជីឈ្មោះសិស្សពី Excel យ៉ាងរហ័ស៖</h4>
                <p className="leading-relaxed font-semibold">
                  ១. លោកគ្រូអ្នកគ្រូអាចទាញយកគំរូដោយចុចប៊ូតុង <strong>«ទាញយកគំរូ Excel»</strong> ដើម្បីទទួលបានឯកសារតារាង ៤ ជួរងាយស្រួល។<br />
                  ២. បើកឯកសារគំរូនោះ រួចវាយបញ្ចូល ឬថតចម្លង (Copy-Paste) តែ៖ <strong>១. អត្តលេខ ២. ឈ្មោះសិស្ស ៣. ភេទ ៤. ថ្នាក់ទី</strong> តែប៉ុណ្ណោះ។<br />
                  ៣. រក្សាទុក រួចចុចប៊ូតុង <strong>«បញ្ចូលពី Excel (.xlsx)»</strong> ដើម្បីនាំចូលឈ្មោះសិស្សទាំងអស់ សម្រាប់ការវាយតម្លៃក្នុងកម្មវិធីភ្លាមៗ!
                </p>
              </div>
            </div>

            {/* Quick dashboard stats */}
            <div className="grid grid-cols-1 md:grid-cols-4 gap-4 font-bold select-none">
              <div className="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
                <div>
                  <p className="text-xs text-slate-500 font-medium font-sans">ចំនួនសិស្សសរុប</p>
                  <p className="text-2xl font-bold text-slate-800 tracking-tight font-sans">{stats.total} នាក់</p>
                </div>
                <div className="w-12 h-12 bg-teal-50 rounded-lg flex items-center justify-center text-teal-600">
                  <User className="w-6 h-6" />
                </div>
              </div>

              <div className="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
                <div>
                  <p className="text-xs text-slate-500 font-medium font-sans">សិស្សស្រី</p>
                  <p className="text-2xl font-bold text-teal-600 tracking-tight font-sans">{stats.females} នាក់</p>
                </div>
                <div className="w-12 h-12 bg-teal-50 rounded-lg flex items-center justify-center text-teal-600 text-xs font-bold font-sans">ស្រី</div>
              </div>

              <div className="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
                <div>
                  <p className="text-xs text-slate-500 font-medium font-sans">មធ្យមភាគចរិយាសម្បទា</p>
                  <p className="text-2xl font-bold text-emerald-600 tracking-tight font-sans">{stats.avgBehavior}/60</p>
                </div>
                <div className="w-12 h-12 bg-emerald-50 rounded-lg flex items-center justify-center text-emerald-600">
                  <Award className="w-6 h-6" />
                </div>
              </div>

              <div className="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
                <div>
                  <p className="text-xs text-slate-500 font-medium font-sans">មធ្យមភាគបំណិនសម្បទា</p>
                  <p className="text-2xl font-bold text-amber-600 tracking-tight font-sans">{stats.avgSkill}/72</p>
                </div>
                <div className="w-12 h-12 bg-amber-50 rounded-lg flex items-center justify-center text-amber-500">
                  <Star className="w-6 h-6" />
                </div>
              </div>
            </div>

            {/* Central content divide split */}
            <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
              <div className="space-y-4">
                <ClassConfigCard 
                  classConfig={classConfig}
                  googleSheetUrl={googleSheetUrl}
                  onConfigChange={handleConfigChange}
                  onGoogleSheetUrlChange={handleGoogleSheetUrlChange}
                />
                <NewStudentForm onAddStudent={handleAddStudent} />
              </div>

              {/* Table section */}
              <div className="lg:col-span-2 bg-white p-5 rounded-xl border border-slate-200 shadow-sm space-y-4">
                <div className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 border-b border-slate-100 pb-3">
                  <h3 className="font-bold text-slate-800 text-sm md:text-base flex items-center gap-1.5 font-muol">
                    <User className="w-5 h-5 text-teal-600" />
                    <span>តារាងឈ្មោះសិស្សក្នុងប្រព័ន្ធ</span>
                  </h3>

                  <div className="flex flex-wrap items-center gap-2">
                    {/* Class selection custom filters */}
                    <div className="flex items-center space-x-1">
                      <span className="text-[10px] font-bold text-slate-500 font-sans">ចម្រោះ៖</span>
                      <select 
                        value={selectedClassFilter} 
                        onChange={(e) => handleFilterChange(e.target.value)}
                        className="text-xs px-2 py-1.5 border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-teal-500 font-bold text-teal-700 cursor-pointer bg-white"
                      >
                        {uniqueClassrooms.map((c) => (
                          <option key={c} value={c}>{c}</option>
                        ))}
                      </select>
                    </div>

                    {/* Searching text field */}
                    <div className="relative">
                      <input 
                        type="text" 
                        placeholder="ស្វែងរកឈ្មោះ..." 
                        value={searchQuery}
                        onChange={(e) => setSearchQuery(e.target.value)}
                        className="pl-9 pr-4 py-1.5 w-full sm:w-44 border border-slate-300 rounded-md text-xs focus:outline-none focus:ring-2 focus:ring-teal-500"
                      />
                      <Search className="w-4 h-4 text-slate-400 absolute left-3 top-2.5" />
                    </div>
                  </div>
                </div>

                <div className="overflow-x-auto rounded-lg border border-slate-100">
                  <table className="min-w-full divide-y divide-slate-200 text-xs">
                    <thead className="bg-slate-50 font-bold">
                      <tr>
                        <th className="px-3 py-3 text-left text-slate-500">អត្តលេខ</th>
                        <th className="px-3 py-3 text-left text-slate-500">ឈ្មោះសិស្ស</th>
                        <th className="px-3 py-3 text-left text-slate-500">ភេទ (ចុចប្តូរ)</th>
                        <th className="px-3 py-3 text-left text-slate-500">ថ្នាក់</th>
                        <th className="px-3 py-3 text-center text-slate-500">ចរិយាលម្អិត (60)</th>
                        <th className="px-3 py-3 text-center text-slate-500">បំណិនលម្អិត (72)</th>
                        <th className="px-3 py-3 text-right text-slate-500">សកម្មភាព</th>
                      </tr>
                    </thead>
                    <tbody className="bg-white divide-y divide-slate-100 font-sans font-semibold">
                      {activeFiltered.filter(s => 
                        s.nameKh.toLowerCase().includes(searchQuery.toLowerCase()) || 
                        s.studentId.toLowerCase().includes(searchQuery.toLowerCase())
                      ).length === 0 ? (
                        <tr>
                          <td colSpan={7} className="px-3 py-8 text-center text-slate-400 font-bold font-sans">
                            មិនមានទិន្នន័យសិស្សក្នុងថ្នាក់ដែលបានជ្រើសរើសនេះឡើយ។
                          </td>
                        </tr>
                      ) : (
                        activeFiltered.filter(s => 
                          s.nameKh.toLowerCase().includes(searchQuery.toLowerCase()) || 
                          s.studentId.toLowerCase().includes(searchQuery.toLowerCase())
                        ).map((s) => {
                          let bS = 0;
                          Object.keys(s.behavior).forEach(k => bS += s.behavior[k]?.length || 0);

                          let sS = 0;
                          Object.values(s.skills || {}).forEach(v => sS += (v as number) || 0);

                          const bL = getBehaviorLevel(bS);
                          const sL = getSkillLevel(sS);
                          const isSel = s.id === activeStudentId;
                          const sexStyle = s.gender === "ស្រី" ? "text-pink-600 bg-pink-50" : "text-blue-600 bg-blue-50";

                          return (
                            <tr 
                              key={s.id} 
                              onClick={() => setActiveStudentId(s.id)}
                              className={`cursor-pointer transition-colors ${isSel ? 'bg-teal-50/70 border-l-4 border-l-teal-600' : 'hover:bg-teal-50/20'}`}
                            >
                              <td className="px-3 py-3 font-mono font-bold text-slate-700">{s.studentId}</td>
                              <td className="px-3 py-3 font-bold text-slate-900">{s.nameKh}</td>
                              <td className="px-3 py-3">
                                <span 
                                  onClick={(e) => {
                                    e.stopPropagation();
                                    handleToggleGender(s.id);
                                  }} 
                                  className={`px-2 py-1 rounded font-bold cursor-pointer transition-all ${sexStyle}`}
                                  title="ចុចប្តូរភេទ"
                                >
                                  {s.gender}
                                </span>
                              </td>
                              <td className="px-3 py-3 text-teal-700 font-bold">{s.className || classConfig.className}</td>
                              <td className="px-3 py-3 text-center">
                                <span className={`px-2 py-0.5 rounded text-[10px] font-bold ${bL.color}`}>{bS} - {bL.text}</span>
                              </td>
                              <td className="px-3 py-3 text-center">
                                <span className={`px-2 py-0.5 rounded text-[10px] font-bold ${sL.color}`}>{sS} - {sL.text}</span>
                              </td>
                              <td className="px-3 py-3 text-right" onClick={(e) => e.stopPropagation()}>
                                <div className="flex items-center justify-end space-x-1.5">
                                  <button 
                                    onClick={() => {
                                      setActiveStudentId(s.id);
                                      setActiveTab("behavior");
                                    }} 
                                    className="p-1 hover:text-emerald-600 text-slate-400 cursor-pointer" 
                                    title="បំពេញចរិយាសម្បទា"
                                  >
                                    <Award className="w-4 h-4" />
                                  </button>
                                  <button 
                                    onClick={() => {
                                      setActiveStudentId(s.id);
                                      setActiveTab("skills");
                                    }} 
                                    className="p-1 hover:text-amber-500 text-slate-400 cursor-pointer" 
                                    title="បំពេញបំណិនសម្បទា"
                                  >
                                    <Star className="w-4 h-4" />
                                  </button>
                                  <button 
                                    onClick={() => handleDeleteStudent(s.id)} 
                                    className="p-1 hover:text-rose-600 text-slate-400 cursor-pointer" 
                                    title="លុបសិស្ស"
                                  >
                                    <Trash2 className="w-4 h-4" />
                                  </button>
                                </div>
                              </td>
                            </tr>
                          );
                        })
                      )}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        )}

        {/* Tab 2: Behaviour evaluations */}
        {activeTab === "behavior" && (
          <BehaviorTab 
            student={activeStudent}
            allStudents={activeFiltered}
            onActiveStudentChange={handleActiveStudentChange}
            onToggleBehaviorItem={handleToggleBehaviorItem}
            getBehaviorLevel={getBehaviorLevel}
          />
        )}

        {/* Tab 3: Extracurricular skills ratings */}
        {activeTab === "skills" && (
          <SkillsTab 
            student={activeStudent}
            allStudents={activeFiltered}
            onActiveStudentChange={handleActiveStudentChange}
            onUpdateSkillScore={handleUpdateSkillScore}
            getSkillLevel={getSkillLevel}
          />
        )}

        {/* Tab 4: Printable Evaluation cards sheets */}
        {activeTab === "report" && (
          <div className="space-y-6 animate-fade-in text-xs font-sans">
            
            {/* Command control action bar */}
            <div className="bg-white p-5 rounded-xl border border-slate-200 shadow-md flex flex-col md:flex-row md:items-center justify-between gap-4 no-print-element font-bold">
              <div className="flex flex-wrap items-center gap-3">
                <span className="font-bold text-slate-600">ចម្រោះថ្នាក់៖</span>
                <select 
                  value={selectedClassFilter} 
                  onChange={(e) => handleFilterChange(e.target.value)}
                  className="px-2.5 py-1.5 border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-teal-500 font-bold text-teal-700 cursor-pointer bg-white"
                >
                  {uniqueClassrooms.map((c) => (
                    <option key={c} value={c}>{c}</option>
                  ))}
                </select>

                <span className="font-bold text-slate-600">ជ្រើសរើសសិស្សបោះពុម្ព៖</span>
                <select 
                  value={activeStudentId || ""} 
                  onChange={(e) => handleActiveStudentChange(e.target.value)}
                  className="px-2.5 py-1.5 border border-slate-300 rounded focus:outline-none focus:ring-2 focus:ring-teal-500 font-semibold cursor-pointer"
                >
                  {activeFiltered.map(s => (
                    <option key={s.id} value={s.id}>{s.nameKh} ({s.gender})</option>
                  ))}
                </select>

                <button 
                  onClick={() => {
                    setActiveTab("ai-helper");
                    handleTriggerGenerateReport(activeStudentId!);
                  }} 
                  className="inline-flex items-center px-3 py-1.5 bg-purple-600 hover:bg-purple-500 text-white font-bold rounded-md shadow-sm transition-all cursor-pointer select-none"
                >
                  <Sparkles className="w-3.5 h-3.5 mr-1.5" />✨ បង្កើតមតិយោបល់ដោយ AI
                </button>
              </div>

              <div className="flex flex-wrap items-center gap-2.5 font-bold">
                <button 
                  onClick={handlePrintAll} 
                  className="inline-flex items-center px-4 py-2 bg-rose-600 hover:bg-rose-500 text-white text-xs font-bold rounded-md shadow-md transition-all border border-rose-500 cursor-pointer animate-pulse"
                  title="បោះពុម្ពសន្លឹកវាយតម្លៃសិស្សទាំងអស់ក្នុងថ្នាក់បច្ចុប្បន្ននេះម្តងទាំងអស់គ្នា"
                >
                  <Printer className="w-4 h-4 mr-2" />បោះពុម្ពសិស្សម្តងទាំងអស់
                </button>

                <button 
                  onClick={() => window.print()}
                  className="inline-flex items-center px-4 py-2 bg-teal-600 hover:bg-teal-500 text-white text-xs font-bold rounded-md shadow-md transition-all border border-teal-500 cursor-pointer"
                >
                  <Printer className="w-4 h-4 mr-2" />បោះពុម្ពសិស្សបច្ចុប្បន្ន
                </button>
              </div>
            </div>

            {/* Instruction banner */}
            <div className="bg-amber-50 border border-amber-200 p-4 rounded-xl no-print-element flex items-start gap-3">
              <Info className="w-5 h-5 text-amber-600 mt-0.5 flex-shrink-0" />
              <div className="text-xs text-amber-800 leading-relaxed font-bold">
                <p className="font-bold">⚠️ ការណែនាំពិសេសសម្រាប់ការរក្សាទុកជា PDF (រឹមក្រដាស 1cm ពេញមួយទំព័រ)៖</p>
                <p className="mt-1 text-[11px] text-slate-700 font-semibold font-sans">
                  លោកគ្រូអ្នកគ្រូអាចចុចប៊ុងតុង <strong>«បោះពុម្ពសិស្សម្តងទាំងអស់»</strong> ពណ៌ក្រហម ដើម្បីបើកប្រព័ន្ធបោះពុម្ពបន្តផ្ទាល់សម្រាប់សិស្សទាំងអស់ក្នុងថ្នាក់បច្ចុប្បន្ន ឬចុចប៊ូតុងពណ៌ខៀវ ដើម្បីបោះពុម្ពសិស្សម្នាក់ៗ។ បន្ទាប់មក សូមបើកជម្រើស <strong>PDF (Microsoft Print to PDF / Save as PDF)</strong> វានឹងរៀបចំរឹមក្រដាស 1cm យ៉ាងស្រស់ស្អាតបំផុតតែមួយទំព័រគត់សម្រាប់សិស្សម្នាក់ៗ!
                </p>
              </div>
            </div>

            {/* A4 interactive live paper preview */}
            <div className="no-print-element shadow-xl rounded-lg p-1 bg-white border border-slate-350 select-none">
              <ReportCard 
                student={activeStudent}
                classConfig={classConfig}
                onTriggerAiComment={async () => ""}
                getBehaviorLevel={getBehaviorLevel}
                getSkillLevel={getSkillLevel}
              />
            </div>
          </div>
        )}

        {/* Tab 5: Generative AI tool configs */}
        {activeTab === "ai-helper" && (
          <AiHelperTab 
            student={activeStudent}
            allStudents={activeFiltered}
            geminiApiKey={geminiApiKey}
            onGeminiApiKeyChange={handleApiKeyChange}
            onActiveStudentChange={handleActiveStudentChange}
            onTriggerGenerateReport={handleTriggerGenerateReport}
            onCommentChange={handleCommentChange}
          />
        )}

      </main>

      {/* Main informative platform Footer */}
      <footer className="bg-slate-800 text-slate-400 py-6 border-t border-slate-700 text-center text-xs no-print-element font-bold font-sans">
        <div className="max-w-7xl mx-auto px-4">
          <p className="font-medium text-slate-300">កម្មវិធីវាយតម្លៃការសិក្សា និងការអភិវឌ្ឍសិស្សបែបឌីជីថល</p>
          <p className="mt-1 text-slate-500 font-bold">គាំទ្រដល់គរុភិបាលក្នុងការកសាងសមត្ថភាពខ្លួនឱ្យក្លាយជា «គ្រូបង្រៀនឌីជីថល» សម្រាប់សតវត្សទី២១</p>
          <div className="flex justify-center space-x-2 mt-3 text-[10px] text-slate-600 font-bold font-mono">
            <span>ឆ្នាំសិក្សា ២០២៦ • ជំនាន់ ៣.៤.០ (Embedded Security Authen Engine)</span>
            <span>•</span>
            <span>គាំទ្រ Google Gemini 3.5 Flash API Direct Integration</span>
          </div>
        </div>
      </footer>

    </div>
  );
}
